# Copy to .env.local and fill in. .env*.local is gitignored.
# Supabase dashboard -> Project Settings -> API

# Public (safe to expose to the browser; used by the app + API routes)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Kakao JavaScript key (developers.kakao.com -> app -> 앱 키 -> JavaScript 키).
# Public by design. Register the site domain under 플랫폼 -> Web and enable
# 카카오톡 공유. Also set this in the Vercel project env. Optional: without it the
# "카카오톡 공유" button falls back to copy-link.
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key

# Cron / sync auth secret (generate: openssl rand -hex 32)
# Set the SAME value in Vercel project env vars.
CRON_SECRET=your-random-secret

# SECRET — service_role key. Bypasses Row Level Security.
# Used ONLY by the local `npm run seed` script. NEVER expose to the browser
# or commit it. Not needed on Vercel.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
